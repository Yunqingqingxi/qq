<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 包含昵称、退出按钮、通话和菜单图标的顶部导航栏 -->
    <include
        android:id="@+id/topBar"
        layout="@layout/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 消息显示区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputArea"
        android:background="#F3F3F3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/inputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F5F5F5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ImageView 作为第一个组件 -->
        <ImageView
            android:id="@+id/inputImageView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/p40" /> <!-- 替换为你的图片资源 -->

        <!-- EditText 作为输入框 -->
        <!-- EditText 作为输入框 -->
        <EditText
            android:id="@+id/inputMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/edittext_input_background"
            android:hint="输入消息"
            android:inputType="text"
            android:padding="8dp"
            tools:ignore="TouchTargetSizeCheck" />



        <ImageView
            android:id="@+id/inputImageView2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/p41" />
        <!-- TextView 作为发送按钮 -->
        <TextView
            android:id="@+id/sendButton"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="发送"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/send_button_background"
            android:padding="10dp"
            tools:ignore="SpeakableTextPresentCheck" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>